{
  "name": "vibecommit",
  "version": "2.0.0",
  "description": "AI-powered git commit message generator with smart suggestions",
  "main": "dist/index.js",
  "bin": {
    "vibecommit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest --coverage",
    "lint": "eslint src/ --ext .ts",
    "prettier": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "commit-message",
    "conventional-commits",
    "cli"
  ],
  "author": "Mark Aardenne",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aardenne/vibecommit"
  },
  "bugs": {
    "url": "https://github.com/aardenne/vibecommit/issues"
  },
  "homepage": "https://github.com/aardenne/vibecommit",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "openai": "^4.50.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "figures": "^6.1.0",
    "gitdiff-parser": "^1.0.0",
    "ini": "^5.0.0",
    "inquirer": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ini": "^4.1.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
